---
import { SERIES, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首頁</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<div class="dropdown">
				<a href="/blog" class="dropdown-toggle">系列 ▾</a>
				<div class="dropdown-menu">
					{SERIES.map((s) => <a href={`/series/${s.slug}/`}>{s.name}</a>)}
				</div>
			</div>
			<HeaderLink href="/about">關於</HeaderLink>
			<HeaderLink href="/contact">聯絡</HeaderLink>
		</div>
		<div class="social-links">
			<a href="/rss.xml" target="_blank">
				<span class="sr-only">訂閱 RSS</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm1.5 2.5c5.523 0 10 4.477 10 10a1 1 0 1 1-2 0 8 8 0 0 0-8-8 1 1 0 0 1 0-2zm0 4a6 6 0 0 1 6 6 1 1 0 1 1-2 0 4 4 0 0 0-4-4 1 1 0 0 1 0-2zm.5 5a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.dropdown {
		position: relative;
		display: inline-block;
	}
	.dropdown-toggle {
		display: inline-block;
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.dropdown-menu {
		position: absolute;
		top: 100%;
		left: 0;
		min-width: 10em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 12%);
		border-radius: 0 0 8px 8px;
		opacity: 0;
		visibility: hidden;
		transform: translateY(-4px);
		transition: 0.15s ease;
		z-index: 10;
	}
	.dropdown:hover .dropdown-menu,
	.dropdown:focus-within .dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}
	.dropdown-menu a {
		display: block;
		padding: 0.6em 1em;
		border-bottom: none;
		white-space: nowrap;
	}
	.dropdown-menu a:hover {
		background: rgb(var(--gray-light));
		color: rgb(var(--accent));
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
