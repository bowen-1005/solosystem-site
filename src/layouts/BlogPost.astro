---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getPillar } from '../consts';

type NavLink = { slug: string; title: string } | null;
type Props = CollectionEntry<'blog'>['data'] & { prev?: NavLink; next?: NavLink };

const { title, description, pubDate, updatedDate, heroImage, pillar, chapter, chapterNum, episode, tags, prev, next } =
	Astro.props;

const pillarInfo = getPillar(pillar);
const epLabel = episode !== undefined ? `EP${String(episode).padStart(2, '0')}` : null;
const chapterLabel = chapter ? (chapterNum && chapterNum > 0 ? `Ch.${chapterNum} ${chapter}` : chapter) : null;
const metaParts = [chapterLabel, epLabel].filter(Boolean);
---

<html lang="zh-Hant">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 700px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 2em;
				padding: 0.5em 0 0;
				text-align: left;
				line-height: 1.3;
			}
			.title h1 {
				margin: 0 0 0.4em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: 0.9em;
			}
			.last-updated-on {
				font-style: italic;
			}
			.series-meta {
				margin: 0 0 0.4em 0;
				font-size: 0.8em;
				letter-spacing: 0.02em;
			}
			.series-meta a {
				color: rgb(var(--accent));
				text-decoration: none;
				font-weight: 700;
			}
			.series-meta a:hover {
				text-decoration: underline;
			}
			.post-tags {
				margin: 0.8em 0 0 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
			}
			.post-tags .tag {
				font-size: 0.75em;
				color: rgb(var(--gray));
				background: rgb(var(--gray-light));
				padding: 0.12em 0.7em;
				border-radius: 999px;
			}
			.post-nav {
				display: flex;
				justify-content: space-between;
				gap: 1em;
				margin-top: 3em;
				padding-top: 1.5em;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.post-nav-link {
				display: flex;
				flex-direction: column;
				gap: 0.3em;
				max-width: 48%;
				text-decoration: none;
				color: rgb(var(--gray-dark));
			}
			.post-nav-link.next {
				text-align: right;
				margin-left: auto;
			}
			.post-nav-link .dir {
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.post-nav-link .t {
				font-weight: 700;
				line-height: 1.4;
			}
			.post-nav-link:hover .t {
				color: rgb(var(--accent));
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						{
							(pillarInfo || metaParts.length > 0) && (
								<p class="series-meta">
									{pillarInfo && <a href={`/${pillarInfo.slug}/`}>{pillarInfo.name}</a>}
									{pillarInfo && metaParts.length > 0 && ' · '}
									{metaParts.join(' · ')}
								</p>
							)
						}
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										最後更新於 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							tags && tags.length > 0 && (
								<p class="post-tags">
									{tags.map((t) => (
										<span class="tag">#{t}</span>
									))}
								</p>
							)
						}
						<hr />
					</div>
					<slot />
					{
						(prev || next) && (
							<nav class="post-nav">
								{prev ? (
									<a class="post-nav-link prev" href={`/blog/${prev.slug}/`}>
										<span class="dir">← 上一篇</span>
										<span class="t">{prev.title}</span>
									</a>
								) : (
									<span />
								)}
								{next ? (
									<a class="post-nav-link next" href={`/blog/${next.slug}/`}>
										<span class="dir">下一篇 →</span>
										<span class="t">{next.title}</span>
									</a>
								) : (
									<span />
								)}
							</nav>
						)
					}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
