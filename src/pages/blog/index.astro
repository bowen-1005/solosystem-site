---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import { PILLARS, SITE_TITLE } from '../../consts';
import { filterPublished, sortBySeries } from '../../series';

const posts = filterPublished(await getCollection('blog'));

// 依 PILLARS 順序分區；只列有文章的主軸
const sections = PILLARS.map((pillar) => ({
	pillar,
	posts: sortBySeries(posts.filter((p) => p.data.pillar === pillar.key)),
})).filter((s) => s.posts.length > 0);
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={`文章 | ${SITE_TITLE}`} description="一人系統的全部文章，依四大主軸分門別類。" />
		<style>
			.intro {
				margin-bottom: 2.5em;
			}
			.intro h1 {
				margin-bottom: 0.2em;
			}
			.intro p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.pillar-section {
				margin-bottom: 3em;
			}
			.pillar-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1em;
				border-bottom: 2px solid rgb(var(--black));
				padding-bottom: 0.4em;
				margin-bottom: 0.3em;
			}
			.pillar-head h2 {
				margin: 0;
				font-size: 1.3em;
			}
			.pillar-head .hook {
				font-size: 0.85em;
				color: rgb(var(--gray));
				font-weight: 400;
				flex-shrink: 0;
			}
			.pillar-head a {
				text-decoration: none;
				color: rgb(var(--black));
			}
			.pillar-head a:hover h2 {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="intro">
				<h1>文章</h1>
				<p>依四大主軸分門別類。想單看一個主軸，點主軸標題進入專頁。</p>
			</div>

			{
				sections.map(({ pillar, posts }) => (
					<section class="pillar-section">
						<a href={`/${pillar.slug}/`}>
							<div class="pillar-head">
								<h2>{pillar.name}</h2>
								<span class="hook">{pillar.hook}</span>
							</div>
						</a>
						{posts.map((post) => (
							<PostCard post={post} />
						))}
					</section>
				))
			}
		</main>
		<Footer />
	</body>
</html>
