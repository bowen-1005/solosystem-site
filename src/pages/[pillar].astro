---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { PILLARS, SITE_TITLE } from '../consts';
import { filterPublished, groupByChapter } from '../series';

export async function getStaticPaths() {
	const posts = filterPublished(await getCollection('blog'));
	return PILLARS.map((pillar) => ({
		params: { pillar: pillar.slug },
		props: {
			pillar,
			groups: groupByChapter(posts.filter((p) => p.data.pillar === pillar.key)),
		},
	}));
}

const { pillar, groups } = Astro.props;
const hasPosts = groups.length > 0;
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<BaseHead title={`${pillar.name} | ${SITE_TITLE}`} description={pillar.hook} />
		<style>
			.pillar-intro {
				margin-bottom: 2.5em;
			}
			.pillar-intro h1 {
				margin-bottom: 0.2em;
			}
			.pillar-intro p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1.05em;
			}
			.chapter {
				margin-bottom: 2.5em;
			}
			.chapter h2 {
				font-size: 1.1em;
				color: rgb(var(--gray-dark));
				border-bottom: 1px solid rgb(var(--gray-light));
				padding-bottom: 0.3em;
				margin-bottom: 0.2em;
			}
			.soon {
				padding: 2em 0;
				color: rgb(var(--gray));
			}
			.back {
				margin-top: 2em;
				font-size: 0.9em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="pillar-intro">
				<h1>{pillar.name}</h1>
				<p>{pillar.hook}</p>
			</div>

			{
				hasPosts ? (
					groups.map((g) => (
						<section class="chapter">
							{g.chapter && g.chapter !== '其他' && (
								<h2>{g.chapterNum > 0 ? `Ch.${g.chapterNum} ${g.chapter}` : g.chapter}</h2>
							)}
							{g.posts.map((post) => (
								<PostCard post={post} />
							))}
						</section>
					))
				) : (
					<p class="soon">這個主軸正在籌備中——先矛後傘，內容會陸續上線。可以先訂閱 RSS 或從其他主軸開始讀。</p>
				)
			}

			<p class="back"><a href="/blog/">← 回全部文章</a></p>
		</main>
		<Footer />
	</body>
</html>
